import pandas as pd

def find_customers(customers: pd.DataFrame, orders: pd.DataFrame) -> pd.DataFrame:
    merged=customers.merge(orders,left_on='id',right_on='customerId',how='left').rename(columns={'name':'Customers'})
    result = merged['customerId'].isna()
    res=merged[result][['Customers']]
    return res
