import pandas as pd

def article_views(views: pd.DataFrame) -> pd.DataFrame:
    df = views[views['author_id']== views['viewer_id']]
    df1 = df['author_id'].unique()
    df1 = sorted(df1)
    result = pd.DataFrame({'id':df1})
    return result
